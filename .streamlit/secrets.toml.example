# Copy to .streamlit/secrets.toml (gitignored) for local dev,
# or paste into Streamlit Community Cloud Secrets UI for deployment.
#
# See: https://docs.streamlit.io/deploy/streamlit-community-cloud/deploy-your-app/secrets-management

# --- Supabase ---
[supabase]
url = "https://your-project.supabase.co"
service_key = "your-service-role-key"

# --- FMP (live prices) ---
[fmp]
api_key = "your-fmp-api-key"

# --- Authentication ---
# Passwords must be pre-hashed with bcrypt.
# Run: python scripts/hash_password.py <your-password>

[cookie]
name = "teyvat_dashboard"
key = "change-this-to-a-random-secret-string"
expiry_days = 30

[credentials.usernames.user1]
email = "user1@example.com"
first_name = "User"
last_name = "One"
password = "$2b$12$REPLACE_WITH_BCRYPT_HASH"
logged_in = false
failed_login_attempts = 0

[credentials.usernames.user2]
email = "user2@example.com"
first_name = "User"
last_name = "Two"
password = "$2b$12$REPLACE_WITH_BCRYPT_HASH"
logged_in = false
failed_login_attempts = 0

[credentials.usernames.user3]
email = "user3@example.com"
first_name = "User"
last_name = "Three"
password = "$2b$12$REPLACE_WITH_BCRYPT_HASH"
logged_in = false
failed_login_attempts = 0
